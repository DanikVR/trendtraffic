{
  "name": "@vibevox/frontend",
  "version": "1.0.6",
  "private": true,
  "//version-rule": "Decimal-carry, max 9 per column: 1.0.9 → 1.1.0, 1.9.9 → 2.0.0. Sync with APP_VERSION in src/components/AppVersion.tsx on every change.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:full": "npm run sitemap && npm run build && npm run prerender",
    "preview": "vite preview",
    "sitemap": "node scripts/sitemap.mjs",
    "prerender": "node scripts/prerender.mjs",
    "translate:locales": "node scripts/translate-locales.mjs",
    "i18n:propagate": "node scripts/propagate-new-keys.mjs",
    "i18n:check": "node scripts/check-i18n-coverage.mjs",
    "i18n:review": "node scripts/review-locales-with-gemini.mjs",
    "i18n:review:apply": "node scripts/review-locales-with-gemini.mjs --apply",
    "i18n:review:fresh": "node scripts/review-locales-with-gemini.mjs --apply --skip-if-fresh",
    "routes:check": "node scripts/check-public-routes.mjs",
    "predeploy:check": "node scripts/predeploy.mjs --check-only",
    "predeploy": "node scripts/predeploy.mjs",
    "predeploy:offline": "node scripts/predeploy.mjs --skip-translate",
    "lighthouse": "node scripts/lighthouse-audit.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@khmyznikov/pwa-install": "^0.6.3",
    "@livekit/components-react": "^2.0.0",
    "@twa-dev/sdk": "^8.0.2",
    "axios": "^1.6.0",
    "clsx": "^2.1.0",
    "framer-motion": "^12.40.0",
    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "livekit-client": "^2.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^14.0.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.0.0"
  }
}

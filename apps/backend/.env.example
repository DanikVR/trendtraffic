# ====================================================================
# VibeVox backend — пример переменных окружения.
# Скопируйте в `apps/backend/.env` и заполните реальными значениями.
# Запуск: npm run dev (tsx watch --env-file=.env) / npm start (node --env-file=.env)
#
# ВАЖНО про секреты внешних сервисов: LiveKit / Stripe / глобальный Gemini /
# токен Telegram-бота НЕ читаются из этого .env — они задаются в АДМИН-ПАНЕЛИ
# (/admin/config → пишется в system-config.json). Здесь только то, что реально
# читает код напрямую из process.env (проверено grep'ом по apps/backend/src).
# ====================================================================

# ── Режим (КРИТИЧНО для прода) ──────────────────────────────────────
# production: отключает dev-логи И ЖЁСТКО запрещает тихий JSON-fallback БД
# (даже без DB_DISABLE_FALLBACK). На VPS всегда production.
NODE_ENV=production

# ── PostgreSQL ──────────────────────────────────────────────────────
# Способ A (рекомендуется для удалённой/managed БД) — одна строка подключения.
# Раскомментируйте и заполните; имеет приоритет над DB_* ниже.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# Способ B — по отдельным переменным (для ЛОКАЛЬНОГО Postgres на VPS, Вариант A):
DB_HOST=localhost
DB_PORT=5432
DB_USER=vibevox_admin
DB_PASSWORD=ЗАМЕНИТЕ_НА_СИЛЬНЫЙ_ПАРОЛЬ
DB_NAME=vibevox_db

# SSL для УДАЛЁННОЙ БД (managed PostgreSQL почти всегда требует SSL).
# Для локального Postgres (Вариант A) — false/не нужно.
# Для строгой проверки сертификата: DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false

# КРИТИЧНО ДЛЯ ПРОДА: запрещает тихий уход в JSON-fallback при недоступной БД.
# На VPS ОБЯЗАТЕЛЬНО true. (В NODE_ENV=production fallback запрещён и так — это
# дублирующая явная защита от потери данных в db_fallback.json.)
DB_DISABLE_FALLBACK=true

# Тонкая настройка пула (необязательно):
# DB_POOL_MAX=20
# DB_CONNECT_TIMEOUT_MS=10000

# Инициализация схемы на новой БД (один раз):  npm run db:setup
# (создаст таблицы из src/db/init.sql; ALTER-миграции применятся при старте сервера)

# ── Безопасность (ОБЯЗАТЕЛЬНО задать в проде) ───────────────────────
# Подпись JWT. БЕЗ него код использует небезопасный хардкод-фолбэк — в проде
# задавайте обязательно: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИТЕ_openssl_rand_hex_32

# 32-байтовый ключ (hex) для AES-256-GCM шифрования секретов tenant'ов
# (SIP-пароли, per-tenant Gemini/Chatwoot ключи). Код читает ИМЕННО это имя.
# Модуль шифрования БРОСАЕТ ошибку, если ключ не задан. openssl rand -hex 32
SIP_ENCRYPTION_KEY=ЗАМЕНИТЕ_openssl_rand_hex_32

# Пароль суперадмина для ПЕРВОГО входа (до смены в /admin/config → superadmin-auth.json).
# В проде ОБЯЗАТЕЛЬНО задайте свой — иначе действует дефолтный пароль из git-истории.
SUPERADMIN_DEFAULT_PASSWORD=ЗАМЕНИТЕ_сильный_пароль_первого_входа

# ── Сервер ──────────────────────────────────────────────────────────
PORT=3001
# FRONTEND_URL — базовый адрес SPA (НЕ backend!). Используется в ссылке письма
# сброса пароля: ${FRONTEND_URL}/auth/reset-password?token=...
# Локально: http://localhost:3000 ; на проде: https://ваш-домен
FRONTEND_URL=http://localhost:3000
# CORS: разрешённые origins (через запятую) — нужно ТОЛЬКО для split-деплоя
# (api на отдельном домене). Для one-domain nginx (фронт+API на одном домене)
# можно не задавать (запросы same-origin). В dev игнорируется (всё разрешено).
# CORS_ORIGINS=https://ваш-домен,https://www.ваш-домен

# ── Публичные адреса backend (для медиа/ссылок) ─────────────────────
# PUBLIC_BASE_URL — облачный Quest Flow скачивает медиа владельца по АБСОЛЮТНОМУ
#   URL; без него outbox отдаёт относительный /uploads/... и файл не скачается.
# APP_BASE_URL  — ссылки в Telegram-уведомлениях владельцу.
# PUBLIC_APP_URL — базовый адрес для партнёрских (?Vibe=) ссылок.
# На одном домене VPS все три обычно равны https://ваш-домен (или https://api.ваш-домен).
PUBLIC_BASE_URL=https://ваш-домен
APP_BASE_URL=https://ваш-домен
PUBLIC_APP_URL=https://ваш-домен

# ── Gemini (модели; глобальный КЛЮЧ — через админ-панель, не тут) ────
GEMINI_FLASH_MODEL=gemini-3.5-flash
# GEMINI_PRO_MODEL=gemini-3.5-pro   # зарезервировано; кодом сейчас не читается

# ── Масштабирование видеоперевода (всё дублируется в /admin/config) ──
# Лимит одновременных переводов (admission control). Дефолт 50.
# MAX_CONCURRENT_TRANSLATION_SESSIONS=50
# Пул доп. Gemini-ключей через запятую. ВАЖНО: из РАЗНЫХ GCP-проектов (лимит per project).
# GEMINI_API_KEYS=AIza...key1,AIza...key2
# Vertex AI вместо Developer API (1000 concurrent + 4M TPM на проект):
# GEMINI_USE_VERTEX=1
# GOOGLE_CLOUD_PROJECT=my-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json

# ── Google OAuth (env-фолбэк; основной источник — админ-панель) ─────
# systemConfig берёт сначала из system-config.json, иначе из этих env.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# (опц.) интеграция Google Calendar в ассистенте — путь/JSON креды сервис-аккаунта.
# GOOGLE_CALENDAR_CREDENTIALS=

# ── Telegram (уведомления админу) ───────────────────────────────────
# TELEGRAM_BOT_TOKEN — задаётся в админ-панели (system-config.json), не тут.
# TELEGRAM_ADMIN_CHAT_IDS — env-фолбэк для списка chat_id получателей (через запятую).
# TELEGRAM_ADMIN_CHAT_IDS=123456789,-1001234567890

# ── ffmpeg (опц.: дословная расшифровка речи из ВИДЕО Quest Flow) ────
# По умолчанию — бандл ffmpeg-static (npm install). Задайте путь, только если
# нужен системный ffmpeg (например на VPS без ffmpeg-static).
# FFMPEG_PATH=/usr/bin/ffmpeg

# ── SMTP (письма: восстановление пароля) ────────────────────────────
# Hostinger: host=smtp.hostinger.com, port=465 (SSL) или 587 (STARTTLS).
# SMTP_FROM должен совпадать с ящиком SMTP_USER (Hostinger проверяет отправителя).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VibeVox <you@your-domain>
# Если SMTP_* пустые — forgot-password не падает; в DEV ссылка сброса печатается в консоль.

# ── Instagram (ПРЯМОЙ Graph API, омниканал фаза IG-0) ───────────────
# Instagram подключается НАПРЯМУЮ к Meta Graph API (Instagram API with Instagram
# Login), а не через Chatwoot — ростовые фичи (Comment-to-DM, карусель, гейт
# подписки, Ice Breakers) Chatwoot не умеет. См. docs/INSTAGRAM_SETUP.md.
# verify_token — придумайте любую строку, ту же впишите в Meta dashboard.
# INSTAGRAM_VERIFY_TOKEN=любая_случайная_строка
# App ID и App Secret приложения Meta. App Secret также проверяет подпись
# вебхука X-Hub-Signature-256. App ID нужен для OAuth-самоподключения (IG-0.5).
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# OAuth-редирект (IG-0.5): магазины подключают свой IG кнопкой «Подключить».
# Должен совпадать с Redirect URI в настройках приложения Meta.
# INSTAGRAM_OAUTH_REDIRECT=https://<домен>/api/instagram/oauth/callback
# ── Тестовый аккаунт (IG-0, без OAuth): один аккаунт через env ──
# Долгоживущий Instagram user access token (из Meta dashboard / token tool).
# INSTAGRAM_ACCESS_TOKEN=
# ID Instagram business-аккаунта (= entry.id во входящем вебхуке).
# INSTAGRAM_BUSINESS_ID=
# tenant VibeVox, которому принадлежит тестовый аккаунт (резолвер без БД).
# INSTAGRAM_DEFAULT_TENANT_ID=
# PUBLIC_BASE_URL (выше) ОБЯЗАТЕЛЕН для отправки медиа — IG скачивает файл по url.

# ── TikTok (Business Messaging API, прямой) ─────────────────────────
# Доступ требует статуса Messaging Partner + привязки к TikTok for Business.
# verify_token — придумайте строку, ту же впишите в TikTok dashboard.
# TIKTOK_VERIFY_TOKEN=
# Access token и id бизнес-аккаунта TikTok (= business_id в вебхуке).
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_BUSINESS_ID=
# tenant VibeVox, которому принадлежит тестовый аккаунт.
# TIKTOK_DEFAULT_TENANT_ID=
# @username аккаунта — для Ref-URL/QR (ссылка в шапку профиля).
# TIKTOK_USERNAME=
# (опц.) база API, если изменится: по умолчанию https://business-api.tiktok.com/open_api/v1.3
# TIKTOK_API_BASE=

# ── WhatsApp (Cloud API, прямой) ────────────────────────────────────
# Нужно: WhatsApp Business аккаунт в Meta + Phone Number ID + permanent token.
# verify_token — придумайте строку, ту же впишите в Meta webhook.
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=                          # проверка подписи вебхука X-Hub-Signature-256
# WHATSAPP_ACCESS_TOKEN=                         # permanent/system-user token
# WHATSAPP_PHONE_NUMBER_ID=                      # = value.metadata.phone_number_id в вебхуке
# WHATSAPP_DEFAULT_TENANT_ID=                    # tenant VibeVox этого номера
# (опц.) WHATSAPP_API_BASE=https://graph.facebook.com/v21.0
# PUBLIC_BASE_URL (выше) нужен для медиа (WA скачивает по HTTPS-url).

# ── Facebook Messenger (Messenger Platform API, прямой) ─────────────
# Нужно: FB-страница + Meta-приложение с продуктом Messenger + page access token.
# MESSENGER_VERIFY_TOKEN=
# MESSENGER_APP_SECRET=                          # проверка подписи вебхука
# MESSENGER_PAGE_TOKEN=                          # page access token
# MESSENGER_PAGE_ID=                             # = entry.id в вебхуке
# MESSENGER_DEFAULT_TENANT_ID=                   # tenant VibeVox страницы
# MESSENGER_PAGE_USERNAME=                       # для m.me ref-ссылки
# (опц.) MESSENGER_API_BASE=https://graph.facebook.com/v21.0
# Webhook поля: messages, messaging_postbacks, feed (для Comment-to-DM).

# ====================================================================
# Задаётся через АДМИН-ПАНЕЛЬ (/admin/config → system-config.json), НЕ через env:
#   LIVEKIT_API_KEY / LIVEKIT_API_SECRET / LIVEKIT_URL / LIVEKIT_WS_URL
#   STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET / STRIPE_PUBLISHABLE_KEY
#   GEMINI_API_KEY (глобальный), TELEGRAM_BOT_TOKEN
# (после первого старта зайдите суперадмином в /admin/config и заполните)
# ====================================================================

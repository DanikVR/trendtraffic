{
  "name": "@vibevox/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch --env-file=.env --exclude db_fallback.json --exclude system-config.json --exclude google-oauth.json --exclude superadmin-auth.json --exclude uploads src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "db:setup": "node --env-file=.env scripts/db-setup.mjs",
    "pretest": "npm run build",
    "test": "tsx --env-file=.env.test --test tests/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@google/genai": "^2.6.0",
    "@livekit/rtc-node": "^0.13.28",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.0.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.8",
    "pg": "^8.11.0",
    "stripe": "^14.21.0",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.2.0"
  }
}
